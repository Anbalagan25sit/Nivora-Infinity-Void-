"""
E-Box Course Automation Tool - REVISED FOR PROJECT-BASED LEARNING
Automates course completion on https://pro.e-box.co.in

ACTUAL E-BOX STRUCTURE (based on screenshots):
- Projects/Problems (not MCQs)
- Topics with phases: i-Learn, i-Explore, i-Analyse, i-Design, i-Assess
- Command line arguments required for code submissions
- Project descriptions with tasks to complete
"""

import logging
import asyncio
import re
from typing import Annotated, Dict, List, Any
from livekit.agents import RunContext, function_tool

logger = logging.getLogger(__name__)

# Hardcoded credentials
EBOX_USERNAME = "SIT25CS170"
EBOX_PASSWORD = "SIT25CS170"
EBOX_LOGIN_URL = "https://pro.e-box.co.in/login"

# Course name mappings
COURSE_MAPPINGS = {
    "differential": "Differential Equations And Complex Analysis",
    "diff eq": "Differential Equations And Complex Analysis",
    "differential equations": "Differential Equations And Complex Analysis",
    "biology": "Biology for Engineers",
    "bio": "Biology for Engineers",
    "chemistry": "Principles of Chemistry in Engineering",
    "chem": "Principles of Chemistry in Engineering",
    "digital electronics": "Digital Electronics",
    "digital logic": "Digital Logic and Design",
    "python": "Programming Fundamentals using Python",
    "programming": "Programming Fundamentals using Python",
}


def extract_course_and_topic(user_input: str) -> Dict[str, Any]:
    """
    Extract course name and topic from natural language input.

    Examples:
    - "finish my course" -> {"course": None, "topic": None, "all": True}
    - "complete differential equations" -> {"course": "Differential Equations...", "topic": None}
    - "do solution of ordinary differential equations" -> {"course": None, "topic": "Solution Of Ordinary...", "all": False}
    """
    input_lower = user_input.lower().strip()

    result = {
        "course": None,
        "topic": None,
        "all": False,
        "phase": None  # i-Learn, i-Explore, i-Analyse, i-Design, i-Assess
    }

    # Check if requesting all courses/topics
    if any(phrase in input_lower for phrase in ["finish course", "complete course", "do course", "finish my course", "complete all"]):
        result["all"] = True

    # Extract phase
    phase_patterns = {
        "learn": "i-Learn",
        "explore": "i-Explore",
        "analyse": "i-Analyse",
        "analyze": "i-Analyse",
        "design": "i-Design",
        "assess": "i-Assess",
    }
    for key, value in phase_patterns.items():
        if key in input_lower:
            result["phase"] = value
            break

    # Extract course name
    for key, value in COURSE_MAPPINGS.items():
        if key in input_lower:
            result["course"] = value
            break

    # Extract specific topic (if mentioned)
    topic_keywords = [
        "solution of ordinary differential equations",
        "vector calculus",
        "analytic functions",
        "complex integration",
        "partial differential equation"
    ]
    for topic in topic_keywords:
        if topic in input_lower:
            result["topic"] = topic.title()
            break

    return result


async def login_to_ebox(browser) -> Dict[str, Any]:
    """Login to E-Box using hardcoded credentials."""
    try:
        logger.info("[EBox] Logging in...")

        # Navigate to login page
        nav_result = await browser.navigate(EBOX_LOGIN_URL)
        if not nav_result.get("success"):
            return {"success": False, "error": f"Failed to load login page: {nav_result.get('error')}"}

        await asyncio.sleep(2)

        # Fill login form
        form_data = {
            "username": EBOX_USERNAME,
            "password": EBOX_PASSWORD,
            "email": EBOX_USERNAME,
            "user": EBOX_USERNAME,
            "login": EBOX_USERNAME,
        }

        fill_result = await browser.fill_form(form_data, submit=True)

        if not fill_result.get("success"):
            return {"success": False, "error": f"Login form fill failed: {fill_result.get('error')}"}

        await asyncio.sleep(3)

        # Verify login success
        current_url = await browser.get_current_url()

        if "login" not in current_url.lower():
            logger.info("[EBox] Login successful!")
            return {"success": True, "message": "Logged in successfully"}
        else:
            return {"success": False, "error": "Login failed - still on login page"}

    except Exception as e:
        logger.error(f"[EBox] Login error: {e}")
        return {"success": False, "error": str(e)}


async def navigate_to_course(browser, course_name: str = None) -> Dict[str, Any]:
    """Navigate to a specific course or return available courses."""
    try:
        logger.info(f"[EBox] Navigating to course: {course_name or 'listing all courses'}")

        # Take screenshot to analyze available courses
        screenshot = await browser.capture_screenshot()

        from computer_use import analyze_screen

        if course_name:
            prompt = f"""
Look at this e-learning dashboard screenshot.

Find the course card/button for "{course_name}" (or similar name like "Differential Equations", "Biology for Engineers", etc.).

Return JSON:
{{
    "found": true,
    "course_name": "exact name as shown on the card",
    "click_description": "visual description of element to click (e.g., 'Enrolled badge with course title...')"
}}

If not found, return {{"found": false, "available_courses": ["list of visible course names"]}}

Return ONLY valid JSON, no markdown.
"""
        else:
            prompt = """
Look at this e-learning dashboard screenshot.

List all available courses visible on the page (look for course cards with "Enrolled" badges).

Return JSON:
{
    "courses": ["Differential Equations And Complex Analysis / Sethu", "Biology for Engineers / SIT", ...]
}

Return ONLY valid JSON.
"""

        result = analyze_screen(prompt, screenshot, temperature=0.2)

        if result.get("error"):
            return {"success": False, "error": result["error"]}

        if course_name:
            if result.get("found"):
                click_desc = result.get("click_description", f"{course_name} course card")

                # Click the course using visual description
                click_result = await browser.click_element(text=click_desc, vision_fallback=True)

                if click_result.get("success"):
                    await asyncio.sleep(2)
                    return {"success": True, "course": result.get("course_name")}
                else:
                    return {"success": False, "error": f"Could not click course: {click_result.get('error')}"}
            else:
                available = result.get("available_courses", [])
                return {"success": False, "error": f"Course '{course_name}' not found. Available: {', '.join(available)}"}
        else:
            courses = result.get("courses", [])
            return {"success": True, "courses": courses}

    except Exception as e:
        logger.error(f"[EBox] Course navigation error: {e}")
        return {"success": False, "error": str(e)}


async def analyze_project_problem(browser) -> Dict[str, Any]:
    """
    Analyze the current project/problem page.
    E-Box uses project-based learning, not MCQs.
    """
    try:
        logger.info("[EBox] Analyzing project problem...")

        screenshot = await browser.capture_screenshot()
        page_html = await browser.get_page_source()

        from computer_use import analyze_screen

        prompt = """
Analyze this E-Box project/problem page.

Extract:
1. Problem title/name
2. Context (what is this about?)
3. Problem description
4. Tasks to complete (bullet points)
5. Whether this requires code/command line arguments
6. Input format (if applicable)
7. Expected output format

Return JSON:
{
    "problem_title": "...",
    "context": "...",
    "problem_description": "...",
    "tasks": ["task 1", "task 2", ...],
    "requires_code": true/false,
    "requires_command_args": true/false,
    "input_format": "...",
    "output_format": "...",
    "programming_language": "Python/Java/..." (if applicable)
}

Return ONLY valid JSON.
"""

        result = analyze_screen(prompt, screenshot, temperature=0.2)

        if result.get("error"):
            return {"success": False, "error": result["error"]}

        return {
            "success": True,
            "problem": result
        }

    except Exception as e:
        logger.error(f"[EBox] Problem analysis error: {e}")
        return {"success": False, "error": str(e)}


async def generate_solution_code(problem_data: Dict[str, Any]) -> Dict[str, Any]:
    """
    Use AI to generate solution code for the project problem.
    """
    try:
        import boto3
        import json

        bedrock = boto3.client('bedrock-runtime', region_name='us-east-1')

        problem_title = problem_data.get("problem_title", "")
        context = problem_data.get("context", "")
        description = problem_data.get("problem_description", "")
        tasks = problem_data.get("tasks", [])
        language = problem_data.get("programming_language", "Python")
        input_format = problem_data.get("input_format", "")
        output_format = problem_data.get("output_format", "")

        prompt = f"""
You are an expert programmer solving an E-Box project problem.

PROBLEM: {problem_title}

CONTEXT: {context}

DESCRIPTION: {description}

TASKS TO COMPLETE:
{chr(10).join([f"- {task}" for task in tasks])}

PROGRAMMING LANGUAGE: {language}

INPUT FORMAT: {input_format}

OUTPUT FORMAT: {output_format}

Generate complete, working code that solves this problem.

Return JSON:
{{
    "code": "complete code solution (properly escaped)",
    "command_line_args": "arguments to pass when running (if needed)",
    "explanation": "brief explanation of the solution approach",
    "test_cases": [
        {{"input": "...", "expected_output": "..."}},
        ...
    ]
}}

Make sure the code is production-ready and follows best practices.

Return ONLY valid JSON (no markdown code blocks).
"""

        response = bedrock.invoke_model(
            modelId='amazon.nova-pro-v1:0',
            body=json.dumps({
                "messages": [{"role": "user", "content": prompt}],
                "inferenceConfig": {
                    "temperature": 0.3,
                    "max_new_tokens": 2000
                }
            })
        )

        response_body = json.loads(response['body'].read())
        result_text = response_body['output']['message']['content'][0]['text']

        # Strip markdown code fences
        result_text = re.sub(r'^```json?\s*', '', result_text.strip())
        result_text = re.sub(r'\s*```$', '', result_text.strip())

        result = json.loads(result_text)

        return {
            "success": True,
            "code": result.get("code", ""),
            "command_args": result.get("command_line_args", ""),
            "explanation": result.get("explanation", ""),
            "test_cases": result.get("test_cases", [])
        }

    except Exception as e:
        logger.error(f"[EBox] Code generation error: {e}")
        return {"success": False, "error": str(e)}


async def submit_solution(browser, code: str, command_args: str = "") -> Dict[str, Any]:
    """
    Submit solution code and command line arguments to E-Box.
    """
    try:
        logger.info("[EBox] Submitting solution...")

        screenshot = await browser.capture_screenshot()

        from computer_use import analyze_screen

        # Find code editor and command line input fields
        prompt = """
Look at this E-Box problem page.

Find:
1. Code editor/textarea (where to paste code)
2. Command line arguments input field
3. Submit/Run button

Return JSON:
{
    "code_editor_selector": "CSS selector or description",
    "command_args_selector": "CSS selector or description",
    "submit_button": "description of submit button",
    "found_all": true/false
}
"""

        fields = analyze_screen(prompt, screenshot, temperature=0.1)

        if not fields.get("found_all"):
            return {"success": False, "error": "Could not locate code editor or submit button"}

        # Fill code editor
        code_editor = fields.get("code_editor_selector")
        code_result = await browser.type_text(code_editor, code, clear_first=True)

        if not code_result.get("success"):
            return {"success": False, "error": "Failed to enter code"}

        # Fill command line arguments (if field exists and args provided)
        if command_args and fields.get("command_args_selector"):
            args_result = await browser.type_text(
                fields.get("command_args_selector"),
                command_args,
                clear_first=True
            )

            if not args_result.get("success"):
                logger.warning(f"[EBox] Could not enter command args: {args_result.get('error')}")

        # Click submit button
        submit_desc = fields.get("submit_button", "submit button")
        submit_result = await browser.click_element(text=submit_desc, vision_fallback=True)

        if not submit_result.get("success"):
            return {"success": False, "error": f"Failed to click submit: {submit_result.get('error')}")

        await asyncio.sleep(3)  # Wait for submission processing

        return {"success": True, "message": "Solution submitted successfully"}

    except Exception as e:
        logger.error(f"[EBox] Submission error: {e}")
        return {"success": False, "error": str(e)}


@function_tool()
async def complete_ebox_course(
    context: RunContext,
    request: Annotated[str, "Natural language request like 'finish differential equations', 'complete biology course', 'do solution of ordinary differential equations problem'"]
) -> str:
    """
    Automatically complete E-Box course projects/problems with AI-powered code generation.

    Supports natural language commands:
    - "finish differential equations course"
    - "complete biology"
    - "do solution of ordinary differential equations"
    - "solve the current problem"

    Uses AWS Nova Pro to analyze problems and generate complete code solutions.
    """
    try:
        from browser_automation import BrowserAutomationEngine

        # Parse the request
        parsed = extract_course_and_topic(request)

        logger.info(f"[EBox] Request parsed: {parsed}")

        # Start browser automation
        async with BrowserAutomationEngine(backend="playwright", headless=False) as browser:
            # Login
            login_result = await login_to_ebox(browser)

            if not login_result.get("success"):
                return f"❌ Login failed: {login_result.get('error')}"

            # Navigate to course if specified
            if parsed["course"]:
                course_result = await navigate_to_course(browser, parsed["course"])

                if not course_result.get("success"):
                    return f"❌ Could not find course: {course_result.get('error')}"

            # If no specific course, list available courses
            if not parsed["course"] and not parsed["topic"]:
                course_list = await navigate_to_course(browser, None)
                if course_list.get("success"):
                    courses = course_list.get("courses", [])
                    return f"📚 Available courses:\n" + "\n".join([f"  • {c}" for c in courses]) + "\n\nPlease specify which course to work on."

            # Analyze current problem
            problem_result = await analyze_project_problem(browser)

            if not problem_result.get("success"):
                return f"❌ Could not analyze problem: {problem_result.get('error')}"

            problem = problem_result["problem"]
            problem_title = problem.get("problem_title", "Unknown")

            logger.info(f"[EBox] Working on: {problem_title}")

            # Generate solution code
            solution_result = await generate_solution_code(problem)

            if not solution_result.get("success"):
                return f"❌ Could not generate solution: {solution_result.get('error')}"

            code = solution_result["code"]
            command_args = solution_result["command_args"]
            explanation = solution_result["explanation"]

            # Submit solution
            submit_result = await submit_solution(browser, code, command_args)

            if not submit_result.get("success"):
                return f"❌ Submission failed: {submit_result.get('error')}"

            # Build response
            response = f"✅ **{problem_title}** completed!\n\n"
            response += f"**Solution Approach:** {explanation}\n\n"

            if command_args:
                response += f"**Command Line Args:** `{command_args}`\n\n"

            response += f"Code submitted successfully! Check the E-Box platform for results."

            return response

    except ImportError as e:
        return f"❌ Browser automation not available: {e}. Install: pip install playwright && playwright install chromium"
    except Exception as e:
        logger.error(f"[EBox] Course completion error: {e}")
        return f"❌ Course automation failed: {str(e)}"


@function_tool()
async def ebox_help_with_problem(
    context: RunContext,
    problem_description: Annotated[str, "Describe the problem or paste the problem statement"]
) -> str:
    """
    Get AI help with understanding and solving an E-Box problem.
    Returns solution approach, code, and explanation.
    """
    try:
        import boto3
        import json

        bedrock = boto3.client('bedrock-runtime', region_name='us-east-1')

        prompt = f"""
You are an expert programmer helping with an E-Box course problem.

PROBLEM:
{problem_description}

Provide:
1. Understanding of what the problem is asking
2. Solution approach (step-by-step)
3. Complete code solution (if applicable)
4. Explanation of key concepts

Return JSON:
{{
    "understanding": "what the problem is asking for",
    "approach": ["step 1", "step 2", ...],
    "code": "complete code solution (if applicable)",
    "key_concepts": ["concept 1", "concept 2", ...],
    "tips": "helpful tips for solving similar problems"
}}

Return ONLY valid JSON.
"""

        response = bedrock.invoke_model(
            modelId='amazon.nova-pro-v1:0',
            body=json.dumps({
                "messages": [{"role": "user", "content": prompt}],
                "inferenceConfig": {
                    "temperature": 0.4,
                    "max_new_tokens": 2000
                }
            })
        )

        response_body = json.loads(response['body'].read())
        result_text = response_body['output']['message']['content'][0]['text']

        # Strip markdown
        result_text = re.sub(r'^```json?\s*', '', result_text.strip())
        result_text = re.sub(r'\s*```$', '', result_text.strip())

        result = json.loads(result_text)

        # Format response
        output = f"**Understanding:** {result.get('understanding', '')}\n\n"
        output += f"**Solution Approach:**\n"
        for i, step in enumerate(result.get('approach', []), 1):
            output += f"{i}. {step}\n"

        if result.get('code'):
            output += f"\n**Code Solution:**\n```\n{result['code']}\n```\n"

        output += f"\n**Key Concepts:** {', '.join(result.get('key_concepts', []))}\n"
        output += f"\n**Tips:** {result.get('tips', '')}"

        return output

    except Exception as e:
        logger.error(f"[EBox] Help error: {e}")
        return f"❌ Could not generate help: {str(e)}"
