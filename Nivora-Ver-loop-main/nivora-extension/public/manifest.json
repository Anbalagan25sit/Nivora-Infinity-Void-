{
  "manifest_version": 3,
  "name": "Nivora Voice Assistant",
  "version": "1.0.0",
  "description": "AI Voice Assistant like Perplexity Comet - powered by LiveKit",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon128.png"
    },
    "default_title": "Nivora Assistant",
    "default_popup": "index.html"
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "optional_permissions": [
    "microphone"
  ],
  "host_permissions": [
    "http://localhost:*",
    "http://127.0.0.1:*",
    "https://*.livekit.cloud"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' ws://localhost:* wss://*.livekit.cloud https://*.livekit.cloud http://localhost:* http://127.0.0.1:*;"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+N",
        "windows": "Alt+N",
        "mac": "Alt+N"
      },
      "description": "Open Nivora Assistant"
    }
  }
}
