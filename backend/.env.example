# ==========================================
# NIVORA BACKEND ENVIRONMENT CONFIGURATION
# ==========================================
# Copy this file to .env and fill in your values.
# DO NOT COMMIT your actual .env file to version control!

# ------------------------------------------
# CORE: LiveKit (Real-time Audio/Video)
# ------------------------------------------
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key_here
LIVEKIT_API_SECRET=your_api_secret_here

# ------------------------------------------
# CORE: AWS Bedrock (Nova Pro LLM & Vision)
# ------------------------------------------
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_BEDROCK_MODEL=amazon.nova-pro-v1:0

# ------------------------------------------
# CORE: Speech-to-Text (Groq Whisper)
# ------------------------------------------
# Free tier available at console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key

# ------------------------------------------
# AGENT TOOLS: E-Box Automation
# ------------------------------------------
EBOX_USERNAME=your_ebox_username
EBOX_PASSWORD=your_ebox_password

# Optional LLM fallbacks for browser-use (Defaults to Bedrock Nova)
# ANTHROPIC_API_KEY=sk-ant-your_key
# OPENAI_API_KEY=sk-proj-your_key

# ------------------------------------------
# AGENT TOOLS: Notion Integration
# ------------------------------------------
NOTION_API_KEY=secret_your_notion_key
NOTION_DEFAULT_DATABASE_ID=your_database_id
NOTION_NOTES_PAGE_ID=your_page_id

# ------------------------------------------
# AGENT TOOLS: Spotify (Optional)
# ------------------------------------------
# Note: Windows native control often works without these, 
# but they are needed for advanced API features.
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REFRESH_TOKEN=your_refresh_token

# ------------------------------------------
# AGENT TOOLS: AWS Extra Services (Optional)
# ------------------------------------------
AWS_S3_BUCKET=nivora-bucket
AWS_DYNAMODB_TABLE=nivora_habits
AWS_SES_SENDER_EMAIL=you@example.com

# NOTE: Gmail and Google Sheets credentials use a `credentials.json` file
# downloaded from Google Cloud Console. Keep it in the root of the backend folder.
